#!/usr/bin/env bash
# =============================================================================
# convox-v3-deploy-debug v1.2.0
#
# Diagnostic tool for capturing pre-healthcheck service logs during Convox deploys.
#
# convox logs does not surface service output until processes pass their health
# check.  Most deploy failures happen before that point.  This script bridges
# the gap by querying the cluster directly using Convox's namespace and label
# conventions.
#
# Usage:
#   convox-v3-deploy-debug --rack <rack> --app <app> [OPTIONS]
#
# Requirements:
#   - kubectl (cluster access -- the wizard sets this up automatically)
#   - python3 (3.6+ for JSON parsing)
#   - curl (for remote convox.yml fetching)
#   - (optional) yq v4+ for reliable convox.yml parsing
#
# License: MIT
# =============================================================================

set -euo pipefail

# Debug: trap ERR to show the failing line when DEBUG=1
trap 'if [[ "${DEBUG:-}" == "1" ]]; then echo "[debug] FAILED at line $LINENO (exit $?): ${BASH_COMMAND}" >&2; fi' ERR

readonly VERSION="1.2.0"
readonly SCRIPT_NAME="convox-v3-deploy-debug"
readonly KUBE_TIMEOUT="--request-timeout=10s"

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
RACK=""
APP=""
SERVICES=()
CONVOX_YML=""
REPO_URL=""
REPO_BRANCH="main"
MANIFEST_PATH="convox.yml"
AGE_SECONDS=300          # 5 minutes
OUTPUT_MODE="terminal"   # terminal | summary | json
LOG_LINES=200
SHOW_EVENTS=true
SHOW_PREVIOUS=true
SHOW_DESCRIBE=false
SHOW_ALL_PODS=false
KUBECONFIG_ARG=""
CONTEXT_ARG=""
NO_COLOR=false
INTERACTIVE=false
CHECKS=()
CLEANUP_FILES=()
OVERVIEW_JSON_FILE=""

# Initialize color variables to empty so they're always defined.
# setup_colors() will set them properly after arg parsing.
RED="" GRN="" YEL="" BLU="" CYN="" MAG="" BLD="" DIM="" RST="" UND=""

# ---------------------------------------------------------------------------
# Colors (disabled when piped or --no-color)
# ---------------------------------------------------------------------------
setup_colors() {
  if [[ "$NO_COLOR" == "true" ]] || [[ ! -t 1 ]]; then
    RED="" GRN="" YEL="" BLU="" CYN="" MAG="" BLD="" DIM="" RST="" UND=""
  else
    RED=$'\033[0;31m' GRN=$'\033[0;32m' YEL=$'\033[0;33m'
    BLU=$'\033[0;34m' CYN=$'\033[0;36m' MAG=$'\033[0;35m'
    BLD=$'\033[1m'    DIM=$'\033[2m'    RST=$'\033[0m'
    # shellcheck disable=SC2034
    UND=$'\033[4m'
  fi
}

# ---------------------------------------------------------------------------
# Logging helpers
# ---------------------------------------------------------------------------
info()  { echo "  ${BLU}${BLD}>${RST} $*" >&2; }
warn()  { echo "  ${YEL}${BLD}!${RST} ${YEL}$*${RST}" >&2; }
err()   { echo "  ${RED}${BLD}x${RST} ${RED}$*${RST}" >&2; }
debug() { [[ "${DEBUG:-}" == "1" ]] && echo "${DIM}    [debug] $*${RST}" >&2 || true; }

# Unicode box-drawing separator (thin line)
separator() {
  echo "${DIM}  $(printf '%.0s─' {1..74})${RST}"
}

# Thick double-line separator for major sections
section_break() {
  echo "${DIM}  $(printf '%.0s━' {1..74})${RST}"
}

# Section header with prominent styling
section_header() {
  local title="$1"
  local color="${2:-$MAG}"
  echo ""
  echo "  ${color}${BLD}${title}${RST}"
  separator
}

# Wizard step header: "  Step 1 of 5 · Dependencies"
step_header() {
  local num="$1" total="$2" label="$3"
  echo "" >&2
  echo "  ${DIM}Step ${num} of ${total}${RST}  ${BLD}${label}${RST}" >&2
  echo "" >&2
}

# ---------------------------------------------------------------------------
# Cleanup on exit
# ---------------------------------------------------------------------------
cleanup() {
  local exit_code=$?
  if [[ $exit_code -ne 0 ]] && [[ $exit_code -ne 130 ]]; then
    # If we exited unexpectedly (not Ctrl-C), show the exit code for debugging
    echo "  ${RED:-}x Script exited unexpectedly (exit code $exit_code).${RST:-}" >&2
    echo "    ${DIM:-}Run with --debug for more detail.${RST:-}" >&2
  fi
  for f in "${CLEANUP_FILES[@]}"; do
    [[ -f "$f" ]] && rm -f "$f"
  done
}
trap cleanup EXIT

# ---------------------------------------------------------------------------
# Usage / Help
# ---------------------------------------------------------------------------
usage() {
  cat <<EOF
${BLD}${SCRIPT_NAME} v${VERSION}${RST}
Capture pre-healthcheck service logs during Convox deployments.

${BLD}USAGE${RST}
  $SCRIPT_NAME --rack <rack> --app <app> [OPTIONS]
  $SCRIPT_NAME --setup          Interactive guided mode
  $SCRIPT_NAME                  (no args also starts guided mode)

${BLD}REQUIRED${RST}
  -r, --rack <name>          Convox rack name
  -a, --app <name>           Convox app name

${BLD}SERVICE DISCOVERY${RST}
  -s, --service <name>       Target a specific service (repeatable)
  -y, --convox-yml <path|url>   Local file path or raw URL to a convox.yml
      --repo <url>           Repo URL to fetch convox.yml from (see below)
      --branch <name>        Branch to use with --repo (default: main)
      --manifest <path>      Path to convox.yml within the repo (default: convox.yml)

${BLD}FILTERING${RST}
  -A, --age <seconds>        Process age threshold in seconds (default: 300)
      --all                  Include all processes, not just unhealthy/new ones
  -c, --checks <name>        Run only specific checks (repeatable). Options:
                               overview  - service rollout status and events
                               init      - init container detection
                               services  - process logs, events, and classification
                             Default: all three. Example: -c services -c init

${BLD}OUTPUT${RST}
  -o, --output <mode>        Output mode: terminal, summary, json (default: terminal)
  -n, --lines <count>        Number of log lines per process (default: 200)
      --no-events            Skip cluster events
      --no-previous          Skip logs from previous crashes
      --describe             Include full process detail (k8s: pod describe)
      --no-color             Disable colored output

${BLD}CLUSTER${RST}
      --kubeconfig <path>    Path to kubeconfig file
      --context <name>       Kubernetes context to use

${BLD}GENERAL${RST}
      --setup                Interactive guided setup (walks you through everything)
  -h, --help                 Show this help
  -v, --version              Show version
      --debug                Enable debug output

${BLD}REPO URL FORMAT${RST}
  The --repo flag accepts repository URLs from GitHub, GitLab, and Bitbucket.
  The script constructs the raw file URL automatically.

  Accepted formats:
    github.com/org/repo
    gitlab.com/org/repo
    bitbucket.org/org/repo
    https://github.com/org/repo
    https://github.com/org/repo.git
    git@github.com:org/repo.git

  Note: only public repos are supported. For private repos, clone locally
  and use --convox-yml <path> instead.

${BLD}EXAMPLES${RST}
  # Basic: debug all services in an app
  $SCRIPT_NAME -r production -a myapp

  # Target a single service
  $SCRIPT_NAME -r production -a myapp -s web

  # Auto-discover services from local convox.yml
  $SCRIPT_NAME -r production -a myapp -y ./convox.yml

  # Auto-discover services from a GitHub repo
  $SCRIPT_NAME -r production -a myapp --repo github.com/myorg/myapp

  # Repo on a feature branch with a non-default manifest path
  $SCRIPT_NAME -r production -a myapp \\
    --repo github.com/myorg/myapp --branch staging --manifest deploy/convox.yml

  # Auto-discover from a raw URL directly
  $SCRIPT_NAME -r production -a myapp \\
    -y https://raw.githubusercontent.com/myorg/myapp/main/convox.yml

  # Wider time window, write to file
  $SCRIPT_NAME -r production -a myapp -A 600 > deploy-debug.txt

  # JSON output for programmatic consumption
  $SCRIPT_NAME -r production -a myapp -o json > debug.json

  # Summary mode for quick triage
  $SCRIPT_NAME -r production -a myapp -o summary

  # Run only service process diagnostics (skip rollout overview and init checks)
  $SCRIPT_NAME -r production -a myapp -c services

  # Run only rollout overview and init container checks
  $SCRIPT_NAME -r production -a myapp -c overview -c init

  # Interactive guided mode (walks you through rack, app, and kubectl setup)
  $SCRIPT_NAME --setup
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing helper: require a value for a flag
# ---------------------------------------------------------------------------
require_arg() {
  if [[ $# -lt 3 ]] || [[ "$3" == -* ]]; then
    err "$1 requires an argument"
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -r|--rack)        require_arg "$1" "$@"; RACK="$2";          shift 2 ;;
      -a|--app)         require_arg "$1" "$@"; APP="$2";           shift 2 ;;
      -s|--service)     require_arg "$1" "$@"; SERVICES+=("$2");   shift 2 ;;
      -y|--convox-yml)  require_arg "$1" "$@"; CONVOX_YML="$2";    shift 2 ;;
      --repo)           require_arg "$1" "$@"; REPO_URL="$2";      shift 2 ;;
      --branch)         require_arg "$1" "$@"; REPO_BRANCH="$2";   shift 2 ;;
      --manifest)       require_arg "$1" "$@"; MANIFEST_PATH="$2"; shift 2 ;;
      -c|--checks)      require_arg "$1" "$@"; CHECKS+=("$2");     shift 2 ;;
      -A|--age)         require_arg "$1" "$@"; AGE_SECONDS="$2";   shift 2 ;;
      -o|--output)      require_arg "$1" "$@"; OUTPUT_MODE="$2";   shift 2 ;;
      -n|--lines)       require_arg "$1" "$@"; LOG_LINES="$2";     shift 2 ;;
      --all)            SHOW_ALL_PODS=true; shift ;;
      --no-events)      SHOW_EVENTS=false;  shift ;;
      --no-previous)    SHOW_PREVIOUS=false; shift ;;
      --describe)       SHOW_DESCRIBE=true; shift ;;
      --no-color)       NO_COLOR=true;      shift ;;
      --kubeconfig)     require_arg "$1" "$@"; KUBECONFIG_ARG="--kubeconfig=$2"; shift 2 ;;
      --kubeconfig=*)   KUBECONFIG_ARG="--kubeconfig=${1#*=}"; shift ;;
      --context)        require_arg "$1" "$@"; CONTEXT_ARG="--context=$2";       shift 2 ;;
      --context=*)      CONTEXT_ARG="--context=${1#*=}"; shift ;;
      --setup)          INTERACTIVE=true;   shift ;;
      --debug)          export DEBUG=1;     shift ;;
      -h|--help)        usage; exit 0 ;;
      -v|--version)     echo "$SCRIPT_NAME v$VERSION"; exit 0 ;;
      *)                err "Unknown option: $1"; usage; exit 1 ;;
    esac
  done
}

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------
validate() {
  if [[ -z "$RACK" ]]; then
    err "Missing required option: --rack"
    echo "Run '$SCRIPT_NAME --help' for usage." >&2
    exit 1
  fi
  if [[ -z "$APP" ]]; then
    err "Missing required option: --app"
    echo "Run '$SCRIPT_NAME --help' for usage." >&2
    exit 1
  fi
  if ! command -v kubectl &>/dev/null; then
    err "kubectl is required but not found in PATH."
    exit 1
  fi
  if ! command -v python3 &>/dev/null; then
    err "python3 is required but not found in PATH."
    err "Python 3.6+ is needed for pod JSON parsing."
    exit 1
  fi
  if [[ -n "$REPO_URL" ]] && [[ -n "$CONVOX_YML" ]]; then
    err "Cannot use both --repo and --convox-yml. Pick one."
    exit 1
  fi
  if [[ -n "$CONVOX_YML" ]] && [[ "$CONVOX_YML" != http* ]] && [[ ! -f "$CONVOX_YML" ]]; then
    err "convox.yml not found at: $CONVOX_YML"
    exit 1
  fi
  case "$OUTPUT_MODE" in
    terminal|summary|json) ;;
    *) err "Invalid output mode: $OUTPUT_MODE (use terminal, summary, or json)"; exit 1 ;;
  esac
  local c
  for c in "${CHECKS[@]}"; do
    case "$c" in
      overview|init|services) ;;
      *) err "Invalid check name: $c (use overview, init, or services)"; exit 1 ;;
    esac
  done
}

# ---------------------------------------------------------------------------
# Check if a given check name should run (true if --checks not specified, or
# if the name was included in the --checks list)
# ---------------------------------------------------------------------------
should_run_check() {
  local name="$1"
  if [[ ${#CHECKS[@]} -eq 0 ]]; then
    return 0  # no filter, run everything
  fi
  local c
  for c in "${CHECKS[@]}"; do
    [[ "$c" == "$name" ]] && return 0
  done
  return 1
}

# ---------------------------------------------------------------------------
# Interactive: yes/no prompt (default is second arg: y or n)
# ---------------------------------------------------------------------------
prompt_yes_no() {
  local prompt_text="$1"
  local default="${2:-y}"
  local hint="[Y/n]"
  [[ "$default" == "n" ]] && hint="[y/N]"

  # Wrap ANSI codes in \001/\002 so readline calculates cursor position correctly
  local rl_prompt
  rl_prompt=$(printf '%s %s ' "$prompt_text" "$hint" | sed $'s/\x1b\\[[0-9;]*m/\x01&\x02/g')
  local answer
  read -erp "$rl_prompt" answer </dev/tty
  answer="${answer:-$default}"
  # bash 4.0+ lowercase
  [[ "${answer,,}" == "y" ]]
}

# ---------------------------------------------------------------------------
# Interactive: numbered menu prompt, prints selection to stdout
# ---------------------------------------------------------------------------
prompt_choice() {
  local prompt_text="$1"
  shift
  local -a options=("$@")
  local count=${#options[@]}

  if [[ "$count" -eq 0 ]]; then
    return 1
  fi

  echo "" >&2
  echo "  ${BLD}${prompt_text}${RST}" >&2
  echo "" >&2
  local i
  for i in "${!options[@]}"; do
    printf '    %s%2d%s  %s\n' "$BLD" "$((i + 1))" "$RST" "${options[$i]}" >&2
  done
  echo "" >&2

  local choice
  while true; do
    read -erp "    Pick [1-${count}]: " choice </dev/tty
    if [[ "$choice" =~ ^[0-9]+$ ]] && [[ "$choice" -ge 1 ]] && [[ "$choice" -le "$count" ]]; then
      echo "${options[$((choice - 1))]}"
      return 0
    fi
    echo "    ${DIM}Enter a number between 1 and ${count}.${RST}" >&2
  done
}

# ---------------------------------------------------------------------------
# Interactive: check dependencies with install guidance
# ---------------------------------------------------------------------------
check_interactive_deps() {
  local all_ok=true
  local platform
  platform="$(uname -s)"

  local -a ok_deps=() missing_deps=() missing_help=()

  # convox CLI
  if command -v convox &>/dev/null; then
    ok_deps+=("convox CLI")
  else
    missing_deps+=("convox CLI")
    local hint="See: https://docs.convox.com/installation/cli"
    case "$platform" in
      Darwin) hint="brew install convox/tap/convox" ;;
      Linux)  hint="curl -L https://convox.com/cli/linux/convox -o /usr/local/bin/convox && chmod +x /usr/local/bin/convox" ;;
    esac
    missing_help+=("convox CLI: $hint")
    all_ok=false
  fi

  # kubectl
  if command -v kubectl &>/dev/null; then
    ok_deps+=("kubectl")
  else
    missing_deps+=("kubectl")
    local hint="See: https://kubernetes.io/docs/tasks/tools/"
    case "$platform" in
      Darwin) hint="brew install kubectl" ;;
      Linux)  hint="curl -LO \"https://dl.k8s.io/release/\$(curl -sL https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl\" && chmod +x kubectl && sudo mv kubectl /usr/local/bin/" ;;
    esac
    missing_help+=("kubectl: $hint  (don't worry about configuring it -- this tool handles that)")
    all_ok=false
  fi

  # python3
  if command -v python3 &>/dev/null; then
    ok_deps+=("python3")
  else
    missing_deps+=("python3")
    local hint="See: https://www.python.org/downloads/"
    case "$platform" in
      Darwin) hint="brew install python3" ;;
      Linux)  hint="sudo apt-get install python3 (Debian/Ubuntu) or sudo yum install python3 (RHEL/Amazon Linux)" ;;
    esac
    missing_help+=("python3: $hint")
    all_ok=false
  fi

  # Render compact status line
  local dep
  for dep in "${ok_deps[@]}"; do
    echo "    ${GRN}${BLD}✓${RST} ${dep}" >&2
  done
  for dep in "${missing_deps[@]}"; do
    echo "    ${RED}${BLD}✗${RST} ${dep}" >&2
  done

  if [[ "$all_ok" == "false" ]]; then
    echo "" >&2
    echo "    ${BLD}To install:${RST}" >&2
    local h
    for h in "${missing_help[@]}"; do
      echo "      ${DIM}${h}${RST}" >&2
    done
    echo "" >&2
    err "Install the missing dependencies above and run this again."
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Interactive guided setup
# ---------------------------------------------------------------------------
interactive_setup() {
  if [[ ! -t 0 ]]; then
    err "Interactive mode requires a terminal."
    err "For non-interactive usage: $SCRIPT_NAME --rack <rack> --app <app>"
    err "Run '$SCRIPT_NAME --help' for all options."
    exit 1
  fi

  echo "" >&2
  echo "  ${BLD}${CYN}$SCRIPT_NAME${RST} ${DIM}v${VERSION}${RST}" >&2
  section_break >&2

  # -- Step 1: Check dependencies ------------------------------------------
  step_header 1 5 "Dependencies"
  check_interactive_deps

  # -- Step 2: Rack selection ----------------------------------------------
  step_header 2 5 "Select Rack"
  info "Fetching available racks..."
  local racks_output
  racks_output=$(convox racks 2>/dev/null || true)

  if [[ -z "$racks_output" ]]; then
    err "Could not list racks. Make sure you are logged into Convox."
    echo "  Run: convox login <your-console-host>" >&2
    exit 1
  fi

  # Parse rack names from "convox racks" output
  # Format: NAME                      PROVIDER  STATUS
  #         nick-dev/test-logs-31626  aws       running
  local -a rack_names=()
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    # Skip header line (starts with NAME)
    [[ "$line" =~ ^NAME[[:space:]] ]] && continue
    local rname
    rname="$(echo "$line" | awk '{print $1}')"
    [[ -n "$rname" ]] && rack_names+=("$rname")
  done <<< "$racks_output"

  if [[ ${#rack_names[@]} -eq 0 ]]; then
    err "No racks found. Set up a rack first."
    echo "  See: https://docs.convox.com/installation/production-rack" >&2
    exit 1
  fi

  # Get current rack name from "convox rack" output
  # Format: Name      test-logs-31626
  #         Provider  aws
  #         ...
  local current_rack_short=""
  current_rack_short=$(convox rack 2>/dev/null | awk '/^Name[[:space:]]/{print $2}' || true)

  # Find the full org/rack name from racks list that matches the short name
  local current_rack=""
  if [[ -n "$current_rack_short" ]]; then
    local r
    for r in "${rack_names[@]}"; do
      # Match "org/short-name" or exact "short-name"
      if [[ "$r" == */"$current_rack_short" ]] || [[ "$r" == "$current_rack_short" ]]; then
        current_rack="$r"
        break
      fi
    done
    # If no match found in racks list, show the short name anyway
    if [[ -z "$current_rack" ]]; then
      current_rack="$current_rack_short"
    fi
  fi

  if [[ -n "$current_rack" ]]; then
    echo "    ${DIM}Current rack:${RST} ${BLD}${current_rack}${RST}" >&2
  fi

  local selected_rack=""

  if [[ ${#rack_names[@]} -eq 1 ]]; then
    selected_rack="${rack_names[0]}"
    echo "    Using ${BLD}${selected_rack}${RST} (only rack available)" >&2
  elif [[ -n "$current_rack" ]]; then
    if prompt_yes_no "  Use current rack ${BLD}${current_rack}${RST}?"; then
      selected_rack="$current_rack"
    else
      selected_rack=$(prompt_choice "Select a rack:" "${rack_names[@]}")
    fi
  else
    selected_rack=$(prompt_choice "Select a rack:" "${rack_names[@]}")
  fi

  # convox CLI commands need the full "org/rack" name, but the script uses
  # just the rack name for k8s namespace construction (rack-app).
  local convox_rack_full="$selected_rack"

  # Strip the "org/" prefix if present to get the short rack name
  if [[ "$selected_rack" == */* ]]; then
    RACK="${selected_rack##*/}"
  else
    RACK="$selected_rack"
  fi
  info "Selected rack: ${BLD}${convox_rack_full}${RST}"

  # -- Step 3: kubectl configuration ---------------------------------------
  step_header 3 5 "Cluster Access"
  info "Setting up temporary cluster access for ${BLD}${convox_rack_full}${RST}..."
  echo "    ${DIM}Running: convox rack kubeconfig --rack $convox_rack_full${RST}" >&2
  echo "" >&2

  local kubeconfig_tmp
  kubeconfig_tmp=$(mktemp "${TMPDIR:-/tmp}/convox-kubeconfig-XXXXXX")
  CLEANUP_FILES+=("$kubeconfig_tmp")

  if convox rack kubeconfig --rack "$convox_rack_full" > "$kubeconfig_tmp" 2>&1; then
    # Verify the file looks like valid kubeconfig (has "clusters:" or "apiVersion:")
    if grep -q "apiVersion\|clusters" "$kubeconfig_tmp" 2>/dev/null; then
      KUBECONFIG_ARG="--kubeconfig=$kubeconfig_tmp"
      echo "    ${GRN}${BLD}✓${RST} Cluster access configured (session only)" >&2
    else
      warn "kubeconfig output does not look valid. Contents:"
      head -5 "$kubeconfig_tmp" | sed 's/^/    /' >&2
      warn "Continuing anyway -- kubectl may already be configured for this cluster."
    fi
  else
    warn "Could not fetch kubeconfig:"
    cat "$kubeconfig_tmp" | sed 's/^/    /' >&2
    warn "Continuing anyway -- kubectl may already be configured for this cluster."
  fi

  # -- Quick connectivity test ------------------------------------------------
  info "Testing cluster connectivity..."
  local kube_test_err
  # shellcheck disable=SC2086
  if kube_test_err=$(kubectl $KUBE_TIMEOUT $KUBECONFIG_ARG get namespaces --no-headers -o custom-columns=NAME:.metadata.name 2>&1); then
    echo "    ${GRN}${BLD}✓${RST} Connected to cluster" >&2
  else
    echo "" >&2
    err "Cannot reach the cluster."
    echo "      ${DIM}$kube_test_err${RST}" | head -3 >&2
    echo "" >&2
    echo "    ${BLD}Things to try:${RST}" >&2
    echo "      ${DIM}- Re-run this wizard to retry${RST}" >&2
    echo "      ${DIM}- Manually configure: convox rack kubeconfig --rack $convox_rack_full > ~/.kube/config${RST}" >&2
    echo "      ${DIM}- Check your network connection${RST}" >&2
    exit 1
  fi

  # -- Step 4: App selection -----------------------------------------------
  step_header 4 5 "Select App"
  info "Fetching apps on rack ${BLD}${convox_rack_full}${RST}..."
  local apps_output
  apps_output=$(convox apps --rack "$convox_rack_full" 2>/dev/null || true)

  if [[ -z "$apps_output" ]]; then
    err "Could not list apps on rack '$convox_rack_full'."
    exit 1
  fi

  # Parse app names from "convox apps" output
  # Format: APP       STATUS    RELEASE
  #         test-app  updating  RMTOBQJTVOJ
  local -a app_names=()
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    # Skip header line (starts with APP)
    [[ "$line" =~ ^APP[[:space:]] ]] && continue
    local aname
    aname="$(echo "$line" | awk '{print $1}')"
    [[ -n "$aname" ]] && app_names+=("$aname")
  done <<< "$apps_output"

  if [[ ${#app_names[@]} -eq 0 ]]; then
    err "No apps found on rack '$convox_rack_full'."
    exit 1
  fi

  local selected_app=""

  if [[ ${#app_names[@]} -eq 1 ]]; then
    selected_app="${app_names[0]}"
    echo "    Using ${BLD}${selected_app}${RST} (only app available)" >&2
  else
    selected_app=$(prompt_choice "Select an app to debug:" "${app_names[@]}")
  fi

  APP="$selected_app"
  info "Selected app: ${BLD}${APP}${RST}"

  # -- Step 5: Optional convox.yml -----------------------------------------
  step_header 5 5 "Service Discovery (optional)"
  echo "    ${DIM}A convox.yml helps discover your service names for better output.${RST}" >&2
  echo "    ${DIM}The tool works fine without it.${RST}" >&2
  echo "" >&2

  if prompt_yes_no "  Do you have a convox.yml to point to?" "n"; then
    echo "" >&2
    local yml_path
    read -erp '    Path or URL: ' yml_path </dev/tty
    if [[ -n "$yml_path" ]]; then
      CONVOX_YML="$yml_path"
    fi
  fi

  # -- Confirm and run ------------------------------------------------------
  echo "" >&2
  section_break >&2
  echo "" >&2
  echo "  ${BLD}Ready to run diagnostics${RST}" >&2
  echo "" >&2
  echo "    Rack      ${BLD}${convox_rack_full}${RST}" >&2
  echo "    App       ${BLD}${APP}${RST}" >&2
  if [[ -n "$CONVOX_YML" ]]; then
    echo "    Manifest  ${BLD}${CONVOX_YML}${RST}" >&2
  fi
  echo "" >&2

  # Show the equivalent CLI command for future use
  local cmd="./$SCRIPT_NAME --rack ${RACK} --app ${APP}"
  [[ -n "$CONVOX_YML" ]] && cmd+=" --convox-yml ${CONVOX_YML}"
  separator >&2
  echo "  ${DIM}Quick-run (skip this wizard next time):${RST}" >&2
  echo "    ${BLD}${cmd}${RST}" >&2
  echo "" >&2
  echo "  ${DIM}Run specific checks only (-c, repeatable, combine as needed):${RST}" >&2
  echo "    ${DIM}-c services${RST}    process logs and classification" >&2
  echo "    ${DIM}-c overview${RST}    service rollout status and events" >&2
  echo "    ${DIM}-c init${RST}        init container detection" >&2
  echo "" >&2
  echo "    ${DIM}Example: ${cmd} -c overview -c services${RST}" >&2
  separator >&2
  echo "" >&2

  if ! prompt_yes_no "  Run diagnostics now?"; then
    echo "" >&2
    info "Exiting. Use the commands above when you're ready."
    exit 0
  fi

  echo "" >&2
  # RACK, APP, CONVOX_YML, and KUBECONFIG_ARG are now set.
  # Control returns to main() which calls validate() and continues.
}

# ---------------------------------------------------------------------------
# kubectl wrapper (includes request timeout)
# ---------------------------------------------------------------------------
kube() {
  # shellcheck disable=SC2086
  kubectl $KUBE_TIMEOUT $KUBECONFIG_ARG $CONTEXT_ARG "$@"
}

# ---------------------------------------------------------------------------
# JSON escape via python3 (handles all control characters correctly)
# ---------------------------------------------------------------------------
json_escape() {
  python3 -c "import json,sys; sys.stdout.write(json.dumps(sys.stdin.read()))" <<< "$1"
}

# ---------------------------------------------------------------------------
# Remote convox.yml: normalize repo URL to a raw file URL
# ---------------------------------------------------------------------------
normalize_repo_url() {
  local raw="$1"

  # Strip trailing .git
  raw="${raw%.git}"

  # Strip leading https:// or http://
  raw="${raw#https://}"
  raw="${raw#http://}"

  # Handle SSH format: git@github.com:org/repo -> github.com/org/repo
  if [[ "$raw" == git@* ]]; then
    raw="${raw#git@}"
    raw="${raw/://}"
  fi

  echo "$raw"
}

build_raw_url() {
  local normalized="$1"
  local branch="$2"
  local path="$3"

  # Strip leading slash from manifest path
  path="${path#/}"

  if [[ "$normalized" == github.com/* ]]; then
    local repo_path="${normalized#github.com/}"
    echo "https://raw.githubusercontent.com/${repo_path}/${branch}/${path}"

  elif [[ "$normalized" == gitlab.com/* ]]; then
    local repo_path="${normalized#gitlab.com/}"
    echo "https://gitlab.com/${repo_path}/-/raw/${branch}/${path}"

  elif [[ "$normalized" == bitbucket.org/* ]]; then
    local repo_path="${normalized#bitbucket.org/}"
    echo "https://bitbucket.org/${repo_path}/raw/${branch}/${path}"

  else
    err "Unsupported repository host in: $normalized"
    err "Supported hosts: github.com, gitlab.com, bitbucket.org"
    err "You can also pass a raw URL directly with --convox-yml <url>"
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Fetch remote convox.yml (from --repo or --convox-yml URL)
# ---------------------------------------------------------------------------
fetch_remote_manifest() {
  local url=""

  if [[ -n "$REPO_URL" ]]; then
    local normalized
    normalized=$(normalize_repo_url "$REPO_URL")
    url=$(build_raw_url "$normalized" "$REPO_BRANCH" "$MANIFEST_PATH")
    debug "Normalized repo: $normalized"
  elif [[ "$CONVOX_YML" == http* ]]; then
    url="$CONVOX_YML"
  else
    return 0
  fi

  if ! command -v curl &>/dev/null; then
    err "curl is required for fetching remote convox.yml files."
    exit 1
  fi

  info "Fetching convox.yml from: $url"
  debug "Full URL: $url"

  local tmpfile
  tmpfile=$(mktemp "${TMPDIR:-/tmp}/convox-yml-XXXXXX.yml")
  CLEANUP_FILES+=("$tmpfile")

  local http_code
  http_code=$(curl -sL -w "%{http_code}" -o "$tmpfile" "$url" 2>/dev/null || echo "000")

  if [[ "$http_code" != "200" ]]; then
    err "Failed to fetch convox.yml (HTTP $http_code)"
    if [[ "$http_code" == "404" ]]; then
      err "File not found. Check the repo URL, branch, and manifest path."
      if [[ -n "$REPO_URL" ]]; then
        err "  Repo:     $REPO_URL"
        err "  Branch:   $REPO_BRANCH"
        err "  Manifest: $MANIFEST_PATH"
        err "  Full URL: $url"
      fi
    elif [[ "$http_code" == "000" ]]; then
      err "Network error. Check your connection and the URL."
    else
      err "Unexpected response. The repo may be private."
      err "For private repos, clone locally and use --convox-yml <path> instead."
    fi
    exit 1
  fi

  # Validate it looks like YAML (basic sanity check)
  if ! grep -qE '^(services|environment|resources|timers):' "$tmpfile" 2>/dev/null; then
    warn "Downloaded file may not be a valid convox.yml (no services/resources section found)."
    warn "Continuing anyway, but service discovery may fail."
  fi

  CONVOX_YML="$tmpfile"
  info "Remote convox.yml fetched successfully."
}

# ---------------------------------------------------------------------------
# Service discovery from convox.yml
# ---------------------------------------------------------------------------
discover_services() {
  if [[ -z "$CONVOX_YML" ]]; then
    return
  fi

  if command -v yq &>/dev/null; then
    info "Reading services from convox.yml using yq"
    local discovered
    discovered=$(yq e '.services | keys | .[]' "$CONVOX_YML" 2>/dev/null || true)
    if [[ -n "$discovered" ]]; then
      while IFS= read -r svc; do
        SERVICES+=("$svc")
      done <<< "$discovered"
      info "Discovered services: ${SERVICES[*]}"
    else
      warn "No services found in convox.yml"
    fi
  else
    info "Reading services from convox.yml using grep (install yq for better parsing)"
    local in_services=false
    while IFS= read -r line; do
      if [[ "$line" =~ ^services: ]]; then
        in_services=true
        continue
      fi
      if $in_services; then
        if [[ "$line" =~ ^[a-z] ]] && [[ ! "$line" =~ ^[[:space:]] ]]; then
          break
        fi
        if [[ "$line" =~ ^[[:space:]]{2}([a-zA-Z0-9_-]+): ]]; then
          SERVICES+=("${BASH_REMATCH[1]}")
        fi
      fi
    done < "$CONVOX_YML"
    if [[ ${#SERVICES[@]} -gt 0 ]]; then
      info "Discovered services: ${SERVICES[*]}"
    else
      warn "Could not parse services from convox.yml"
    fi
  fi
}

